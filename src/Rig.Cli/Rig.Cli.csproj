<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <OutputType>Exe</OutputType>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>rig</ToolCommandName>
    <PackageId>rig</PackageId>
    <Version>0.1.1</Version>
    <Description>CLI tool that indexes .NET solutions and exposes per-entry-point call graphs annotated with external effects.</Description>
    <Authors>dv00d00</Authors>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/dv00d00/coderig</RepositoryUrl>
    <PackageProjectUrl>https://github.com/dv00d00/coderig</PackageProjectUrl>

    <ServerGarbageCollection>true</ServerGarbageCollection>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="System.CommandLine" />
  </ItemGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Rig.Tests" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Rig.Analysis\Rig.Analysis.csproj" />
    <ProjectReference Include="..\Rig.Storage\Rig.Storage.csproj" />
  </ItemGroup>
  <ItemGroup>
    <None Include="builtin-rules.json" Pack="true" PackagePath="tools/net10.0/any/builtin-rules.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <None Include="wwwroot\**\*" Pack="true" PackagePath="tools/net10.0/any/wwwroot/">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
</Project>
